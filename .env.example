APP_NAME="World Cup 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/worldcup2026-app/public

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=worldcup2026
DB_USERNAME=root
DB_PASSWORD=

# API Keys (NEVER expose in frontend)
APIFOOTBALL_KEY=your_apifootball_key_here
OPENWEATHER_KEY=your_openweather_key_here

# Admin panel password
ADMIN_PASSWORD=change_me_in_production

# Cache TTL (seconds)
CACHE_LIVE=60
CACHE_FIXTURES=300
CACHE_STANDINGS=300
CACHE_PLAYERS=86400
CACHE_WEATHER=1800

# CORS
FRONTEND_URL=http://localhost

# Google AdSense (optional) - get from https://adsense.google.com
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXXX

# Laravel defaults
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
